{
  "name": "@iwsdk/vite-plugin-dev",
  "version": "0.2.2",
  "type": "module",
  "description": "Vite plugin for IWSDK development — XR emulation, AI agent tooling, and Playwright browser",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "iwsdk-dev-mcp": "./dist/mcp-server.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rollup -c rollup.injection.config.js && rollup -c rollup.config.js",
    "build:plugin": "rollup -c rollup.config.js",
    "build:injection": "rollup -c rollup.injection.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "rollup -c --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "vite",
    "plugin",
    "webxr",
    "emulation",
    "iwsdk",
    "ai",
    "polyfill",
    "meta",
    "quest",
    "mcp"
  ],
  "author": "Felix Zhang <fe1ix@meta.com>",
  "license": "MIT",
  "dependencies": {
    "@iwer/devui": "^2.2.0",
    "@iwer/sem": "^0.2.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "iwer": "^2.2.0",
    "playwright": "^1.58.2",
    "sharp": "^0.33.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
